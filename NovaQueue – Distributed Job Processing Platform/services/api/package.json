{
  "name": "@novaqueue/api",
  "version": "2.0.0",
  "description": "NovaQueue REST API Service | Created by CaptainCode",
  "author": "CaptainCode",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "migrate": "ts-node src/database/migrations/runner.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "redis": "^4.6.10",
    "pg": "^8.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "@novaqueue/shared": "*"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.5.0",
    "@types/pg": "^8.10.2",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.3",
    "ts-jest": "^29.1.1",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0"
  }
}
